# Copie este arquivo para .env e preencha o token.
# O arquivo .env NÃO é commitado (está no .gitignore).

# Personal Access Token com permissão: repo (read + write contents)
# Gerar em: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_SeuTokenAqui

# Repositório no formato owner/repo
GITHUB_REPO=ProsperWare/ascendimacy-idc

# Branch de destino
GITHUB_BRANCH=master
